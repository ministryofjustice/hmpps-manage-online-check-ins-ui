{
  "name": "hmpps-manage-online-check-ins-ui",
  "version": "0.0.1",
  "description": "HMPPS Manage Online Check Ins Ui",
  "repository": "git@github.com:ministryofjustice/hmpps-manage-online-check-ins-ui.git",
  "license": "MIT",
  "scripts": {
    "prepare": "hmpps-precommit-hooks-prepare",
    "build": "node esbuild/esbuild.config.js --build",
    "start": "node $NODE_OPTIONS dist/server.js | bunyan -o short",
    "start:dev": "concurrently -k -p \"[{name}]\" -n \"Build,Node\" -c \"green.bold,blue.bold\" \"node esbuild/esbuild.config.js --build --watch\" \"node esbuild/esbuild.config.js --dev-server\"",
    "start-feature": "npm run start-node-feature",
    "start-feature:dev": "export $(cat feature.env) && concurrently -k -p \"[{name}]\" -n \"Build,Node\" -c \"green.bold,blue.bold\" \"node esbuild/esbuild.config.js --build --watch\" \"node esbuild/esbuild.config.js --feature-dev-server\"",
    "start-node-feature": "npx nyc instrument dist --nycrc-path ./.nycrc && node $NODE_DEBUG_OPTION --env-file=feature.env dist/server.js | bunyan -o short",
    "watch-node-feature": "export $(cat feature.env) && nodemon --watch dist/ $NODE_DEBUG_OPTION dist/server.js | bunyan -o short",
    "wiremock": "npx wiremock --port 9091 --root-dir wiremock --local-response-templating",
    "lint": "eslint . --cache --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc && tsc -p integration_tests",
    "test": "jest --coverage",
    "test:ci": "jest --coverage --runInBand",
    "security_audit": "npx audit-ci --config audit-ci.json",
    "int-test": "cypress run --spec='integration_tests/e2e/**/*.cy.ts' --config video=false",
    "int-test-ui": "cypress open --e2e --browser chrome",
    "int-test-ci": "cypress run --config video=false",
    "clean": "rm -rf dist build node_modules stylesheets",
    "coverage-report": "rm -rf coverage && mkdir -p coverage && cpy cypress_coverage/coverage-final.json coverage --rename=int-{{basename}} --flat && cpy test_results/jest/coverage-final.json coverage --rename=unit-{{basename}} --flat && npx nyc report --reporter lcov -t coverage --report-dir coverage --exclude-after-remap false",
    "setup": "npm ci && hmpps-npm-script-run-allowlist"
  },
  "engines": {
    "node": "^24",
    "npm": "^11"
  },
  "nyc": {
    "report-dir": "cypress_coverage",
    "reporter": [
      "text",
      "json"
    ],
    "lines": 0
  },
  "jest": {
    "resolver": "<rootDir>/jest-resolver.js",
    "transformIgnorePatterns": [
      "node_modules/(?!(uuid|@smithy|@aws-sdk|@ministryofjustice/hmpps-audit-client|@ministryofjustice/probation-search-frontend)/)"
    ],
    "moduleNameMapper": {
      "^uuid$": "<rootDir>/node_modules/uuid/dist/index.js"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "isolatedModules": true
        }
      ],
      "^.+\\.js$": "babel-jest"
    },
    "collectCoverageFrom": [
      "server/**/*.{ts,js,jsx,mjs}"
    ],
    "coveragePathIgnorePatterns": [
      ".*.test.ts",
      "node_modules",
      "integration_tests",
      "wiremock",
      "server/@types",
      ".*jest.config.js",
      "server/app.ts",
      "server/index.ts",
      ".*.cy.ts"
    ],
    "coverageDirectory": "test_results/jest/",
    "coverageReporters": [
      "json",
      "lcov"
    ],
    "testMatch": [
      "<rootDir>/(server|job)/**/?(*.)(cy|test).{ts,js,jsx,mjs}"
    ],
    "testEnvironment": "node",
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "test_results/jest/"
        }
      ],
      [
        "./node_modules/jest-html-reporter",
        {
          "outputPath": "test_results/unit-test-reports.html"
        }
      ]
    ],
    "moduleFileExtensions": [
      "web.js",
      "js",
      "json",
      "node",
      "ts"
    ]
  },
  "nodemonConfig": {
    "ignore": [
      ".circleci/*",
      "migrations/*",
      "node_modules/*",
      "test/*",
      "integration_tests/*"
    ],
    "delay": 2500,
    "ext": "js,json,html,njk"
  },
  "lint-staged": {
    "*.{ts,js,css}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1063.0",
    "@ministryofjustice/frontend": "^9.0.0",
    "@ministryofjustice/hmpps-arns-frontend-components-lib": "2.1.0",
    "@ministryofjustice/hmpps-audit-client": "1.1.3",
    "@ministryofjustice/hmpps-auth-clients": "3.0.0",
    "@ministryofjustice/hmpps-azure-telemetry": "^1.0.0",
    "@ministryofjustice/hmpps-monitoring": "^2.1.0",
    "@ministryofjustice/hmpps-probation-frontend-components": "1.0.3",
    "@ministryofjustice/hmpps-rest-client": "^2.1.0",
    "@types/cypress__code-coverage": "^3.10.2",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "agentkeepalive": "4.6.0",
    "bunyan": "^1.8.15",
    "bunyan-format": "^0.2.1",
    "compression": "^1.8.1",
    "connect-flash": "^0.1.1",
    "connect-redis": "^9.0.0",
    "csrf-sync": "^4.2.1",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "glob": "^13.0.6",
    "govuk-frontend": "6.1.0",
    "helmet": "^8.2.0",
    "http-errors": "^2.0.1",
    "jwt-decode": "^4.0.0",
    "lodash": "4.18.1",
    "luxon": "3.7.2",
    "multer": "2.2.0",
    "nocache": "^4.0.0",
    "node-mocks-http": "1.17.2",
    "nunjucks": "^3.2.4",
    "passport": "^0.7.0",
    "passport-oauth2": "^1.8.0",
    "prom-client": "15.1.3",
    "redis": "6.0.0",
    "superagent": "^10.3.0",
    "url-value-parser": "2.2.0",
    "uuid": "14.0.1",
    "wiremock": "^3.13.1"
  },
  "devDependencies": {
    "@cypress/code-coverage": "4.0.3",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@jgoz/esbuild-plugin-typecheck": "^4.0.4",
    "@ministryofjustice/eslint-config-hmpps": "^1.0.3",
    "@ministryofjustice/frontend-types": "2.0.0",
    "@ministryofjustice/hmpps-npm-script-allowlist": "0.0.6",
    "@ministryofjustice/hmpps-precommit-hooks": "3.0.1",
    "@playwright/test": "^1.60.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/bunyan": "^1.8.11",
    "@types/bunyan-format": "^0.2.9",
    "@types/compression": "^1.8.1",
    "@types/connect-flash": "0.0.40",
    "@types/cypress__code-coverage": "^3.10.2",
    "@types/express-session": "^1.19.0",
    "@types/govuk-frontend": "5.11.0",
    "@types/http-errors": "^2.0.5",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "4.17.24",
    "@types/luxon": "3.7.1",
    "@types/multer": "2.1.0",
    "@types/node": "^24.13.1",
    "@types/nunjucks": "^3.2.6",
    "@types/passport": "^1.0.17",
    "@types/passport-oauth2": "^1.8.0",
    "@types/superagent": "^8.1.10",
    "@types/supertest": "^7.2.0",
    "audit-ci": "^7.1.0",
    "autoprefixer": "^10.5.2",
    "aws-sdk-client-mock": "^4.1.0",
    "concurrently": "^10.0.3",
    "cypress": "^15.18.0",
    "cypress-file-upload": "^5.0.8",
    "cypress-multi-reporters": "^2.0.5",
    "cypress-plugin-tab": "^2.0.0",
    "del": "8.0.1",
    "esbuild": "^0.28.1",
    "esbuild-plugin-clean": "^1.0.1",
    "esbuild-plugin-copy": "^2.1.1",
    "esbuild-plugin-manifest": "^1.0.5",
    "esbuild-sass-plugin": "^3.7.0",
    "jest": "^30.4.2",
    "jest-html-reporter": "^4.4.0",
    "jest-junit": "^17.0.0",
    "jsonwebtoken": "^9.0.3",
    "lint-staged": "^17.0.7",
    "nock": "^14.0.15",
    "nyc": "^18.0.0",
    "postcss": "^8.5.16",
    "postcss-preset-env": "11.3.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  }
}
