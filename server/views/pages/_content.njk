{% extends "../partials/layout.njk" %}
{% block beforeContent %}
  {# {% if breadcrumb and not change %}
    {{ govukBreadcrumbs({
      items: [
        {
          text: "Cases",
          href: "/case"
        },
        {
          text: headerPersonName.forename + ' ' + headerPersonName.surname,
          href: "/case/" + crn,
          attributes: { "data-ai-id": "breadcrumbPersonNameLink" }
        },
        {
          text: "Appointments",
          href: "/case/" + crn + "/appointments"
        },
        {
          text: breadcrumb
        }
      ]
    }) }}
  {% elif backLink %}
    {{ govukBackLink({
      href: backLink
    }) }}
  {% endif %} #}
{% endblock %}

{% block content %}
  {% if crn %}
    {% if not checkinPhotoPage %}
      {% include "../partials/pop-header.njk" %}
      <hr class="govuk-section-break govuk-section-break--visible govuk-section-break--l">
    {% endif %}
  {% endif %}

  <div id="main-content" class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% block heading %}
        {% if title %}
          <h2 class="govuk-heading-l govuk-!-margin-bottom-6" data-qa="pageHeading">
            {{ title }}
          </h2>
        {% endif %}
      {% endblock %}

      {% block primary %}{% endblock %}

    </div>
  </div>
{% endblock %}
